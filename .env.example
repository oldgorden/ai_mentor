# ============================================================
# AI Mentor — API 密钥配置（模板）
# ============================================================
# 使用说明：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 填入你拥有的 API 密钥，不需要的留空即可
#   3. 切勿将 .env 提交到版本控制
# ============================================================

# ── custom (Mimo / 自定义 OpenAI 兼容) ──
CUSTOM_OPENAI_API_KEY=your_custom_api_key_here
CUSTOM_OPENAI_BASE_URL=https://your-custom-endpoint.com/v1

# ── custom2 (DeepSeek-v4 / Kimi / GLM 等) ──
CUSTOM2_OPENAI_API_KEY=your_custom2_api_key_here
CUSTOM2_OPENAI_BASE_URL=https://your-custom2-endpoint.com/v1

# ── 讯飞星辰 ──
XFYUN_API_KEY=your_xfyun_api_key_here
XFYUN_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2

# ── Anthropic (Claude / c_anth 兼容) ──
CUSTOM_ANTHROPIC_API_KEY=your_anthropic_api_key_here
CUSTOM_ANTHROPIC_BASE_URL=

# ── Ollama 本地 ──
OLLAMA_API_KEY=

# ── 原生 OpenAI (GPT / o1 / o3) ──
OPENAI_API_KEY=your_openai_api_key_here

# ── DeepSeek ──
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Google Gemini ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── OpenRouter ──
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── HuggingFace ──
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ── OpenCode Go ──
OPENCODE_GO_API_KEY=your_opencode_go_api_key_here

# ── Semantic Scholar ──
S2_API_KEY=your_s2_api_key_here
